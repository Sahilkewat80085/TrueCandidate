{
  "manifest_version": 3,
  "name": "TrueCandidate Google Meet Connector",
  "version": "1.0",
  "description": "Chrome extension to stream Google Meet participant and webcam events to TrueCandidate.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
